<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% if title %}{{ title }} - {{ site.title }}{% else %}{{ site.title }}{% endif %}</title>
  <meta name="description" content="{% if description %}{{ description }}{% else %}{{ site.description }}{% endif %}">
  <link rel="canonical" href="{{ site.url }}{{ page.url }}">
  <style>
    /* 基础极简样式，保证结构清晰 */
    body { font-family: -apple-system, sans-serif; line-height: 1.6; max-width: 800px; margin: 0 auto; padding: 20px; color: #333; }
    header { border-bottom: 1px solid #eee; padding-bottom: 20px; }
    .site-logo { font-size: 24px; font-weight: bold; text-decoration: none; color: #000; }
    nav { margin-top: 10px; }
    nav a { margin-right: 15px; text-decoration: none; color: #0066cc; }
    main { padding: 20px 0; }
    footer { margin-top: 40px; padding-top: 20px; border-top: 1px solid #eee; font-size: 14px; }
    .friend-links a { margin-right: 15px; color: #666; text-decoration: none; }
    .friend-links a:hover { text-decoration: underline; }
    .post-list { list-style: none; padding: 0; }
    .post-list li { margin-bottom: 15px; }
    .post-meta { color: #888; font-size: 14px; }
  </style>
</head>
<body>

  <header>

    <div class="header-hd">
      <a href="/" class="site-logo">DeepSeek Hub</a>
    </div>
    <nav>
      <a href="/">首页</a>
      <a href="/posts/">文章列表</a>
    </nav>
  </header>

  <main>
    {{ content | safe }}
  </main>

  <footer>
    <div class="friend-links">
      <strong>友情链接：</strong>
      {% for link in site.friendLinks %}
        <a href="{{ link.url }}" target="_blank" rel="noopener">{{ link.name }}</a>
      {% endfor %}
    </div>
    <p>&copy; 2026 {{ site.title }} | 基于 deepseek 构建</p>
  </footer>


  {% if isHome or isPost %}
    {% if site.laTrack.enabled %}
    <script charset="UTF-8" id="LA_COLLECT" src="//sdk.51.la/js-sdk-pro.min.js"></script>
    <script>LA.init({id:"{{ site.laTrack.id }}",ck:"{{ site.laTrack.ck }}"})</script>
    {% endif %}
  {% endif %}

</body>
</html>