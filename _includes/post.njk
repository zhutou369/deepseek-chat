---
layout: base.njk
isPost: true
---

<article>
  <nav class="breadcrumb" style="font-size: 14px; color: #666; margin-bottom: 10px;">
    <a href="{{ locale | localePath(locales) }}" style="color: #666;">{{ t.postBreadcrumbHome }}</a> &gt;
    <a href="{{ locale | postPath }}" style="color: #666;">{{ t.postBreadcrumbPosts }}</a> &gt;
    <span>{{ t.postBreadcrumbBody }}</span>
  </nav>

  <header class="post-header">
    <h1 style="font-size: 28px; margin-bottom: 10px;">{{ title }}</h1>
    <div class="post-meta" style="margin-bottom: 20px;">
      <span>{{ t.postPublished }}: {{ date | dateFilter }}</span>{% if updated %} · {{ t.postUpdated }} {{ updated | dateFilter }}{% endif %}
      <span> · {{ t.brand }}</span>
    </div>
  </header>

  <div class="post-content">
    {{ content | safe }}
  </div>

  <div class="post-footer-nav" style="margin-top: 40px; padding: 15px; background: #f9f9f9; border-radius: 4px;">
    <h3 style="margin-top: 0; font-size: 16px;">{{ t.postReadMore }}</h3>
    <ul>
      {%- if translationKey %}
      {%- set localePosts = collections.pillarPosts | forLocale(locale) %}
      {%- set previousPost = localePosts | getPreviousCollectionItem(page) %}
      {%- set nextPost = localePosts | getNextCollectionItem(page) %}
      {% else %}
      {%- set previousPost = collections.indexablePosts | getPreviousCollectionItem(page) %}
      {%- set nextPost = collections.indexablePosts | getNextCollectionItem(page) %}
      {% endif %}
      <li>{{ t.postPrev }}：
        {% if previousPost %}
          <a href="{{ previousPost.url }}">{{ previousPost.data.title }}</a>
        {% else %}
          {{ t.postNone }}
        {% endif %}
      </li>
      <li>{{ t.postNext }}：
        {% if nextPost %}
          <a href="{{ nextPost.url }}">{{ nextPost.data.title }}</a>
        {% else %}
          {{ t.postNone }}
        {% endif %}
      </li>
    </ul>
    <p style="text-align: right; margin-bottom: 0;"><a href="{{ locale | postPath }}">{{ t.postBackList }} &rarr;</a></p>
  </div>
</article>

<script type="application/ld+json">
{{ {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": title,
  "description": description,
  "datePublished": date | htmlDate,
  "dateModified": (updated | htmlDate) if updated else (date | htmlDate),
  "inLanguage": t.htmlLang,
  "author": {
    "@type": "Organization",
    "name": t.brand
  },
  "publisher": {
    "@type": "Organization",
    "name": t.brand,
    "url": site.url
  },
  "mainEntityOfPage": site.url + page.url
} | dump | safe }}
</script>
<script type="application/ld+json">
{{ {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": t.postBreadcrumbHome,
      "item": site.url + (locale | localePath(locales))
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": t.postBreadcrumbPosts,
      "item": site.url + (locale | postPath)
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": title,
      "item": site.url + page.url
    }
  ]
} | dump | safe }}
</script>
