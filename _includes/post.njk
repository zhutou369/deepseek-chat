---
layout: base.njk
isPost: true
---

<article>

  <nav class="breadcrumb" style="font-size: 14px; color: #666; margin-bottom: 10px;">
    <a href="/" style="color: #666;">首页</a> &gt; 
    <a href="/posts/" style="color: #666;">文章中心</a> &gt; 
    <span>正文</span>
  </nav>

  <header class="post-header">
    <!-- 内容页唯一的 h1 -->
    <h1 style="font-size: 28px; margin-bottom: 10px;">{{ title }}</h1>
    <div class="post-meta" style="margin-bottom: 20px;">
      <span>发布日期: {{ date | dateFilter }}</span> | 
      <span>作者: {{ site.author }}</span>
    </li>
  </header>

  <!-- 文章正文 -->
  <div class="post-content">
    {{ content | safe }}
  </div>


  <div class="post-footer-nav" style="margin-top: 40px; padding: 15px; background: #f9f9f9; border-radius: 4px;">
    <h3 style="margin-top: 0; font-size: 16px;">延伸阅读</h3>
    <ul>
      <li>上一篇：{% if page.previous %}<a href="{{ page.previous.url }}">{{ page.previous.data.title }}</a>{% else %}已经是最新一篇了{% endif %}</li>
      <li>下一篇：{% if page.next %}<a href="{{ page.next.url }}">{{ page.next.data.title }}</a>{% else %}敬请期待下一期更新{% endif %}</li>
    </ul>
    <p style="text-align: right; margin-bottom: 0;"><a href="/posts/">返回文章列表 &rarr;</a></p>
  </div>
</article>