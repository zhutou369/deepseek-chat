---
layout: base.njk
isPost: true
---

<article>
  <nav class="breadcrumb" style="font-size: 14px; color: #666; margin-bottom: 10px;">
    <a href="/" style="color: #666;">首页</a> &gt;
    <a href="/posts/" style="color: #666;">技术文章</a> &gt;
    <span>正文</span>
  </nav>

  <header class="post-header">
    <h1 style="font-size: 28px; margin-bottom: 10px;">{{ title }}</h1>
    <div class="post-meta" style="margin-bottom: 20px;">
      <span>发布日期: {{ date | dateFilter }}</span>{% if updated %} · 更新于 {{ updated | dateFilter }}{% endif %}
      <span> · {{ site.brand }}</span>
    </div>
  </header>

  <div class="post-content">
    {{ content | safe }}
  </div>

  <div class="post-footer-nav" style="margin-top: 40px; padding: 15px; background: #f9f9f9; border-radius: 4px;">
    <h3 style="margin-top: 0; font-size: 16px;">延伸阅读</h3>
    <ul>
      {%- set previousPost = collections.indexablePosts | getPreviousCollectionItem(page) %}
      {%- set nextPost = collections.indexablePosts | getNextCollectionItem(page) %}
      <li>上一篇：
        {% if previousPost %}
          <a href="{{ previousPost.url }}">{{ previousPost.data.title }}</a>
        {% else %}
          暂无
        {% endif %}
      </li>
      <li>下一篇：
        {% if nextPost %}
          <a href="{{ nextPost.url }}">{{ nextPost.data.title }}</a>
        {% else %}
          暂无
        {% endif %}
      </li>
    </ul>
    <p style="text-align: right; margin-bottom: 0;"><a href="/posts/">返回文章列表 &rarr;</a></p>
  </div>
</article>

<script type="application/ld+json">
{{ {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": title,
  "description": description,
  "datePublished": date | htmlDate,
  "dateModified": (updated | htmlDate) if updated else (date | htmlDate),
  "author": {
    "@type": "Organization",
    "name": site.brand
  },
  "publisher": {
    "@type": "Organization",
    "name": site.brand,
    "url": site.url
  },
  "mainEntityOfPage": site.url + page.url
} | dump | safe }}
</script>
<script type="application/ld+json">
{{ {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "首页",
      "item": site.url + "/"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "技术文章",
      "item": site.url + "/posts/"
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": title,
      "item": site.url + page.url
    }
  ]
} | dump | safe }}
</script>
