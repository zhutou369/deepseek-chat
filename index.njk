---
layout: base.njk
isHome: true
---

<!-- 整个首页有且仅有这一个 h1 -->
<h1>{{ site.title }}</h1>
<p class="site-intro">{{ site.description }}</p>

<section style="margin-top: 30px;">
  <h2>最新更新文章</h2>
  <ul class="post-list">
    <!-- 使用 11ty 过滤器 limit(5) 获取最新5篇文章 -->
    {% for post in collections.posts | reverse | limit(5) %}
      <li>
        <span class="post-meta">{{ post.date | dateFilter }}</span>
        <h3><a href="{{ post.url }}">{{ post.data.title }}</a></h3>
        <p>{{ post.data.description }}</p>
      </li>
    {% else %}
      <li>暂无最新文章</li>
    {% endfor %}
  </ul>
  
  <p><a href="/posts/" style="font-weight: bold;">查看更多 DeepSeek 教程文章 &rarr;</a></p>
</section>